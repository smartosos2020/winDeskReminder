<Window x:Class="WinDeskReminder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WinDeskReminder.Controls"
        xmlns:models="clr-namespace:WinDeskReminder.Models"
        Title="WinDeskReminder"
        Width="286"
        Height="268"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        Loaded="Window_Loaded">
    <Grid>
        <controls:SegmentedHandle x:Name="CollapsedHandle"
                                  ItemsSource="{Binding Items}"
                                  Visibility="Collapsed" />

        <Border x:Name="Shell"
                CornerRadius="16"
                Padding="10"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="0"
                                  Opacity="0.16"
                                  Color="#0F172A" />
            </Border.Effect>
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,8"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ContentControl ContentTemplate="{StaticResource LogoIconTemplate}"
                                    Width="28"
                                    Height="28" />
                    <TextBlock Text="健康提醒"
                               Foreground="{StaticResource TextDarkBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="{Binding PauseActionGlyph}"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="PauseAll_Click"
                            ToolTip="{Binding PauseActionText}"
                            Margin="0,0,6,0" />
                    <Button Content="&#xE713;"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="Settings_Click"
                            ToolTip="设置" />
                </StackPanel>
            </Grid>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ReminderItem}">
                        <Border CornerRadius="10"
                                Padding="7"
                                Margin="0,0,0,6"
                                BorderBrush="{StaticResource BorderGrayBrush}"
                                BorderThickness="1"
                                Background="#FAFFFFFF">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="IconBubble"
                                        Width="34"
                                        Height="34"
                                        CornerRadius="17"
                                        Background="{Binding AccentSoftBrush}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <ContentControl x:Name="ReminderIcon"
                                                    Content="{Binding IconKind}"
                                                    ContentTemplate="{StaticResource StandIconTemplate}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                </Border>

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding RemainingText}"
                                               Foreground="{StaticResource TextDarkBrush}"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               FontFamily="Inter, Segoe UI"
                                               VerticalAlignment="Center" />
                                    <ProgressBar Grid.Row="1"
                                                 Width="74"
                                                 HorizontalAlignment="Left"
                                                 Margin="0,2,0,0"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Foreground="{Binding AccentBrush}"
                                                 Value="{Binding ProgressPercent, Mode=OneWay}">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar" BasedOn="{StaticResource SlimProgressBarStyle}">
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>
                                </Grid>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <Button Content="{Binding PrimaryActionGlyph}"
                                            Style="{StaticResource CardIconButtonStyle}"
                                            Click="PrimaryAction_Click"
                                            Tag="{Binding}"
                                            ToolTip="{Binding PrimaryActionText}"
                                            Margin="0,0,4,0" />
                                    <Button Content="&#xE7F7;"
                                            Style="{StaticResource CardIconButtonStyle}"
                                            Click="Snooze_Click"
                                            Tag="{Binding}"
                                            ToolTip="稍后提醒"
                                            Margin="0,0,4,0" />
                                    <Button Content="&#xE72C;"
                                            Style="{StaticResource CardIconButtonStyle}"
                                            Click="Reset_Click"
                                            Tag="{Binding}"
                                            ToolTip="重置" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IconKind}" Value="water">
                                <Setter TargetName="ReminderIcon" Property="ContentTemplate" Value="{StaticResource WaterIconTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IconKind}" Value="eye">
                                <Setter TargetName="ReminderIcon" Property="ContentTemplate" Value="{StaticResource EyeIconTemplate}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,2,0,0">
                <Ellipse Width="7"
                         Height="7"
                         Fill="{StaticResource MintGreenBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0" />
                <TextBlock Text="⌁"
                           Foreground="{StaticResource TextMediumBrush}"
                           FontSize="15"
                           LineHeight="12"
                           VerticalAlignment="Center"
                           Margin="0,-2,4,0" />
                <TextBlock Text="{Binding SystemStateText}"
                           Foreground="{StaticResource TextMediumBrush}"
                           FontSize="10"
                           VerticalAlignment="Center" />
            </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
