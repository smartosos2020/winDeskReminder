<Window x:Class="WinDeskReminder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="560"
        Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="WinDeskReminder"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#0F172A" />
            <TextBlock Text="桌面小挂件与提醒设置"
                       Margin="0,4,0,0"
                       Foreground="#64748B" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="取消"
                    Background="#E2E8F0"
                    Foreground="#0F172A"
                    Click="Cancel_Click" />
            <Button Content="保存"
                    Background="#2563EB"
                    Foreground="#FFFFFF"
                    Click="Save_Click" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="#FFFFFF" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <CheckBox Content="启用屏幕边缘小挂件"
                                  IsChecked="{Binding WidgetEnabled}"
                                  FontSize="14"
                                  Foreground="#0F172A" />
                        <CheckBox Content="提醒时播放声音"
                                  IsChecked="{Binding SoundEnabled}"
                                  Margin="0,10,0,0"
                                  FontSize="14"
                                  Foreground="#0F172A" />
                        <CheckBox Content="开机自动启动"
                                  IsChecked="{Binding StartWithWindows}"
                                  Margin="0,10,0,0"
                                  FontSize="14"
                                  Foreground="#0F172A" />

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="吸附边缘" VerticalAlignment="Center" Foreground="#334155" />
                            <ComboBox x:Name="EdgeBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Height="30"
                                      SelectedItem="{Binding DockEdge}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="显示器" Margin="0,12,0,0" VerticalAlignment="Center" Foreground="#334155" />
                            <ComboBox x:Name="ScreenBox"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Height="30"
                                      Margin="0,12,0,0"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="DeviceName"
                                      SelectedValue="{Binding ScreenDeviceName}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="背板透明度" Margin="0,12,0,0" VerticalAlignment="Center" Foreground="#334155" />
                            <Slider Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,12,0,0"
                                    Minimum="0.25"
                                    Maximum="1"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding BackdropOpacity}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="无操作暂停" Margin="0,12,0,0" VerticalAlignment="Center" Foreground="#334155" />
                            <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,12,0,0">
                                <TextBox Width="80"
                                         HorizontalAlignment="Left"
                                         Text="{Binding IdlePauseMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text=" 分钟"
                                           Foreground="#334155"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                            </DockPanel>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="勿扰时段" Margin="0,12,0,0" VerticalAlignment="Center" Foreground="#334155" />
                            <CheckBox Grid.Row="4"
                                      Grid.Column="1"
                                      Content="启用"
                                      IsChecked="{Binding QuietHoursEnabled}"
                                      Margin="0,12,0,0"
                                      Foreground="#334155" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="勿扰时间" Margin="0,12,0,0" VerticalAlignment="Center" Foreground="#334155" />
                            <StackPanel Grid.Row="5"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="0,12,0,0">
                                <TextBox Width="70"
                                         Text="{Binding QuietHoursStart, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text=" 至 "
                                           Foreground="#334155"
                                           VerticalAlignment="Center"
                                           Margin="8,0" />
                                <TextBox Width="70"
                                         Text="{Binding QuietHoursEnd, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFFFF" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="提醒项目"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <Button Content="新增"
                                    DockPanel.Dock="Right"
                                    Background="#E2E8F0"
                                    Foreground="#0F172A"
                                    Click="AddReminder_Click" />
                        </DockPanel>

                        <ItemsControl x:Name="ReminderList" ItemsSource="{Binding Reminders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            Padding="12"
                                            Margin="0,0,0,10"
                                            Background="#FCFDFF">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Row="0"
                                                     Grid.Column="0"
                                                     Height="30"
                                                     FontSize="14"
                                                     FontWeight="SemiBold"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Row="0"
                                                    Grid.Column="1"
                                                    Content="删除"
                                                    Background="#FEE2E2"
                                                    Foreground="#991B1B"
                                                    Tag="{Binding}"
                                                    Margin="10,0,0,0"
                                                    Click="DeleteReminder_Click" />

                                            <StackPanel Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Orientation="Horizontal"
                                                        Margin="0,10,0,0">
                                                <CheckBox Content="启用"
                                                          IsChecked="{Binding IsEnabled}"
                                                          Foreground="#334155"
                                                          VerticalAlignment="Center" />
                                                <CheckBox Content="声音"
                                                          IsChecked="{Binding SoundEnabled}"
                                                          Foreground="#334155"
                                                          Margin="16,0,0,0"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Text="图标"
                                                           Foreground="#334155"
                                                           Margin="18,0,8,0"
                                                           VerticalAlignment="Center" />
                                                <ComboBox Width="90"
                                                          Height="30"
                                                          SelectedValue="{Binding IconKind, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Tag">
                                                    <ComboBoxItem Content="站立" Tag="stand" />
                                                    <ComboBoxItem Content="喝水" Tag="water" />
                                                    <ComboBoxItem Content="护眼" Tag="eye" />
                                                </ComboBox>
                                            </StackPanel>

                                            <Grid Grid.Row="2"
                                                  Grid.ColumnSpan="2"
                                                  Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="间隔(分钟)"
                                                           Foreground="#334155"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Column="1"
                                                         Width="72"
                                                         HorizontalAlignment="Left"
                                                         Text="{Binding WorkMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="执行(分钟)"
                                                           Foreground="#334155"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Column="3"
                                                         Width="72"
                                                         HorizontalAlignment="Left"
                                                         Text="{Binding ActionMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
