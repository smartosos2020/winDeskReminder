<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="WinDeskReminder"
    Manufacturer="WinDeskReminder"
    Version="$(var.ProductVersion)"
    UpgradeCode="{BDB67A49-3F71-49D1-A0F6-1468C9E6D4B2}"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of WinDeskReminder is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="WinDeskReminder" Level="1">
      <ComponentRef Id="ApplicationExe" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="WinDeskReminder">
        <Component Id="ApplicationExe" Guid="{4D664692-57E0-4C75-8E8B-4BE35B9B2D31}">
          <File
            Id="WinDeskReminderExe"
            Source="$(var.PublishDir)\WinDeskReminder.exe"
            KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="WinDeskReminder">
        <Component Id="StartMenuShortcut" Guid="{82163E3D-2117-421C-8ECF-9EBB17919144}">
          <Shortcut
            Id="ApplicationStartMenuShortcut"
            Name="WinDeskReminder"
            Description="WinDeskReminder"
            Target="[INSTALLFOLDER]WinDeskReminder.exe"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
          <RegistryValue
            Root="HKCU"
            Key="Software\WinDeskReminder"
            Name="Installed"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>
  </Package>
</Wix>
